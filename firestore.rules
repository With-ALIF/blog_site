rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // REVISION 43 - FINAL GLOBAL FIX FOR COLLECTION GROUP COMMENTS
    
    // Global rule for comments to support Admin Collection Group queries
    // This allows listing all comments across all posts for authenticated admins
    match /{path=**}/comments/{commentId} {
      allow read, list: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Category Rules: Anyone can read, only admin can write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // BlogPost Rules
    match /posts/{postId} {
      allow read, list: if true;
      allow write: if request.auth != null;
    }

    // Subscriber Rules: Anyone can subscribe and check for duplicates
    match /subscribers/{subscriberId} {
      allow create: if true;
      allow read: if true; 
      allow write, delete: if request.auth != null;
    }
  }
}
